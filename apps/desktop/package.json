    "@open-conductor/views": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "electron-updater": "^6.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.5.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@open-conductor/eslint-config": "workspace:*",
    "@open-conductor/typescript-config": "workspace:*",
