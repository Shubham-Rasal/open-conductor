# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/open_conductor?sslmode=disable

# Server
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Optional: non-PATH OpenCode CLI (also accepts MULTICA_OPENCODE_PATH for compatibility)
# OPENCODE_PATH=/opt/homebrew/bin/opencode

# Auth
JWT_SECRET=change-me-in-production

# Website (apps/web) — GitHub repo slug for release API and links
# Format: owner/repo  (e.g. your-org/open-conductor)
GITHUB_REPO=open-conductor/open-conductor
# Optional: GitHub token to avoid rate limiting when fetching releases
# GITHUB_TOKEN=ghp_...
