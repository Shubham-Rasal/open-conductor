# Database (SQLite — path is relative to the server working directory)
DATABASE_URL=file:./open_conductor.db

# Server
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Optional: non-PATH OpenCode CLI (also accepts MULTICA_OPENCODE_PATH for compatibility)
# OPENCODE_PATH=/opt/homebrew/bin/opencode

# Optional: model lists in workspace chat (server process reads these; OpenCode uses `opencode models` without keys)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Auth
JWT_SECRET=change-me-in-production

# Website (apps/web) — GitHub repo slug for release API and links
# Format: owner/repo  (e.g. your-org/open-conductor)
GITHUB_REPO=Shubham-Rasal/open-conductor
# Optional: GitHub token to avoid rate limiting when fetching releases
# GITHUB_TOKEN=ghp_...
